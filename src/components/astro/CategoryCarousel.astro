---
import type { Category } from "../../lib/supabase";

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
---

<!-- Sticky Categories -->
<div class="sticky top-14 sm:top-16 z-40 bg-neutral-50/95 backdrop-blur-sm border-b border-neutral-200 shadow-sm -mx-4 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center gap-3 overflow-x-auto py-3 scrollbar-hide">
      <button
        class="category-filter flex-shrink-0 bg-neutral-900 text-white px-5 py-2.5 rounded-full font-medium text-sm whitespace-nowrap"
        data-slug="all">Todas</button
      >
      {
        categories.map((category) => (
          <button
            class="category-filter flex-shrink-0 bg-white text-neutral-700 px-5 py-2.5 rounded-full font-medium text-sm whitespace-nowrap border border-neutral-300 hover:bg-neutral-100 hover:border-neutral-400 transition-all"
            data-slug={category.slug}
          >
            {category.name}
          </button>
        ))
      }
    </div>
  </div>
</div>

<style>
  /* Ocultar scrollbar */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
