---
import { getSupabaseImage } from "../../lib/supabase";
import { AddToCartButton } from "../react/AddToCartButton";
import type { Product } from "../../lib/supabase";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const { name, price, currency, slug, description, images } = product;

// Obtener la primera imagen de la relación product_images
const firstImage = images && images.length > 0 ? images[0] : null;
const imageUrl = getSupabaseImage(firstImage?.image_url);

// Preparar datos para el botón de añadir al carrito
const cartItem = {
  id: product.id,
  name,
  price,
  currency,
  slug,
  image: imageUrl,
};
---

<!--
  COMPONENTE: ProductCard (Vertical)

  Tarjeta vertical para grid de productos
  Muestra badge "Más Vendido" si está marcado como featured
  Todas las tarjetas tienen la misma altura para consistencia visual
-->
<div
  class="product-card bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-shadow"
>
  <a href={`/productos/${slug}`} class="block relative">
    <!-- Badge "Más Vendido" -->
    {
      product.featured && (
        <div class="absolute top-2 left-2 z-10">
          <span class="bg-gray-800 text-white text-xs font-bold px-3 py-1 rounded-md">
            Más Vendido
          </span>
        </div>
      )
    }

    <!-- Imagen del producto (altura fija) -->
    <div class="product-card-image aspect-square overflow-hidden bg-neutral-100">
      <img
        src={imageUrl}
        alt={name}
        class="w-full h-full object-contain p-4 hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  </a>

  <!-- Información del producto (altura fija) -->
  <div class="product-card-info p-4 flex flex-col">
    <a href={`/productos/${slug}`}>
      <h3
        class="text-neutral-800 font-semibold text-sm mb-1 line-clamp-2 hover:text-neutral-700 transition-colors"
        style="min-height: 2.5rem;"
      >
        {name}
      </h3>
    </a>

    <p class="text-neutral-500 text-xs mb-3 line-clamp-2" style="min-height: 1.5rem;">
      {
        description && description.length > 80
          ? description.substring(0, 70) + "..."
          : description || ""
      }
    </p>

    <!-- Precios -->
    <div class="flex items-center gap-2 mb-3">
      <span class="text-neutral-900 font-bold text-lg">
        $ {price.toLocaleString()}
        {currency}
      </span>
    </div>

    <!-- Botón de añadir al carrito (React Island) - empujado al fondo -->
    <div class="mt-auto">
      <AddToCartButton client:load product={cartItem} />
    </div>
  </div>
</div>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Altura fija para la imagen */
  .product-card-image {
    height: 200px;
  }

  /* Altura mínima fija para la info */
  .product-card-info {
    min-height: 160px;
  }
</style>
