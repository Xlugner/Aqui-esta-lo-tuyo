---
import { getSupabaseImage } from "../../lib/supabase";
import { AddToCartButton } from "../react/AddToCartButton";
import type { Product } from "../../lib/supabase";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const { name, price, currency, slug, description, images } = product;

// Obtener la primera imagen de la relación product_images
const firstImage = images && images.length > 0 ? images[0] : null;
const imageUrl = getSupabaseImage(firstImage?.image_url);

// Preparar datos para el botón de añadir al carrito
const cartItem = {
  id: product.id,
  name,
  price,
  currency,
  slug,
  image: imageUrl,
};
---

<!--
  COMPONENTE: ProductCard (Vertical)

  Tarjeta profesional con altura FIJA forzada
  Todas las tarjetas lucen iguales
-->
<div class="product-card flex flex-col h-full bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:border-gray-300 transition-all duration-300">
  <a href={`/productos/${slug}`} class="block relative">
    <!-- Badge "Más Vendido" -->
    {
      product.featured && (
        <div class="absolute top-2 left-2 z-20">
          <span class="bg-green-500 text-white text-xs font-semibold px-2 py-1 rounded-full shadow-sm">
            ★ Más Vendido
          </span>
        </div>
      )
    }

    <!-- Imagen - siempre misma altura -->
    <div class="card-image w-full bg-gray-50 flex items-center justify-center overflow-hidden">
      <img
        src={imageUrl}
        alt={name}
        class="w-full h-full object-contain p-3 hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  </a>

  <!-- Info - altura fija forzada -->
  <div class="card-info flex flex-col flex-1 p-3">
    <!-- Título con máximo 2 líneas -->
    <a href={`/productos/${slug}`} class="block">
      <h3 class="text-gray-900 font-medium text-sm leading-tight line-clamp-2 hover:text-green-600 transition-colors">
        {name}
      </h3>
    </a>

    <!-- Descripción ocultada para uniformidad -->
    <!-- <p class="text-gray-400 text-xs mt-1 line-clamp-1">{description}</p> -->

    <!-- Precio al fondo -->
    <div class="mt-auto pt-2">
      <span class="text-gray-900 font-bold text-lg">
        ${price.toLocaleString()}
        <span class="text-xs font-normal text-gray-500 ml-1">{currency}</span>
      </span>
    </div>

    <!-- Botón -->
    <div class="pt-2">
      <AddToCartButton client:load product={cartItem} />
    </div>
  </div>
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Imagen con altura FIJA - misma para todas */
  .card-image {
    height: 160px;
  }

  /* Info con altura FIJA también */
  .card-info {
    min-height: 120px;
  }

  /* Hover en imagen */
  .card-image img {
    transition: transform 0.3s ease;
  }
  .card-image:hover img {
    transform: scale(1.05);
  }

  /* Mobile: más pequeño */
  @media (max-width: 640px) {
    .card-image {
      height: 120px;
    }
    .card-info {
      min-height: 100px;
      padding: 0.5rem;
    }
  }
</style>
