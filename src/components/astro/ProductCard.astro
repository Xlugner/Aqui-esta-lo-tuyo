---
import { getSupabaseImage } from "../../lib/supabase";
import { AddToCartButton } from "../react/AddToCartButton";
import type { Product } from "../../lib/supabase";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const { name, price, currency, slug, description, images } = product;

// Obtener la primera imagen de la relación product_images
const firstImage = images && images.length > 0 ? images[0] : null;
const imageUrl = getSupabaseImage(firstImage?.image_url);

// Preparar datos para el botón de añadir al carrito
const cartItem = {
  id: product.id,
  name,
  price,
  currency,
  slug,
  image: imageUrl,
};
---

<!--
  COMPONENTE: ProductCard (Vertical)

  Tarjeta profesional limpia con:
  - Imagen cuadrada consistente
  - Título con línea de ajuste
  - Precio claro
  - Botón de añadir al carrito
  - Badge "Más Vendido" profesional
-->
<div class="product-card bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:border-gray-200 transition-all duration-300 group">
  <a href={`/productos/${slug}`} class="block relative">
    <!-- Badge "Más Vendido" -->
    {
      product.featured && (
        <div class="absolute top-3 left-3 z-20">
          <span class="bg-green-500 text-white text-xs font-semibold px-3 py-1 rounded-full shadow-sm">
            ★ Más Vendido
          </span>
        </div>
      )
    }

    <!-- Imagen del producto -->
    <div class="product-card-image bg-gray-50 relative">
      <img
        src={imageUrl}
        alt={name}
        class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  </a>

  <!-- Información del producto -->
  <div class="product-card-info p-4 flex flex-col bg-white">
    <a href={`/productos/${slug}`} class="block">
      <h3 class="text-gray-900 font-semibold text-sm leading-snug line-clamp-2 hover:text-green-600 transition-colors">
        {name}
      </h3>
    </a>

    <p class="text-gray-400 text-xs mt-1 line-clamp-1">
      {
        description && description.length > 50
          ? description.substring(0, 45) + "..."
          : description || ""
      }
    </p>

    <!-- Precio prominent -->
    <div class="mt-3 mb-3">
      <span class="text-gray-900 font-bold text-xl">
        ${price.toLocaleString()}
        <span class="text-xs font-normal text-gray-500">{currency}</span>
      </span>
    </div>

    <!-- Botón de añadir al carrito -->
    <div class="mt-auto">
      <AddToCartButton client:load product={cartItem} />
    </div>
  </div>
</div>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Imagen cuadrada consistente - responsive */
  .product-card-image {
    aspect-ratio: 1;
    height: auto;
    max-height: 220px;
  }

  /* Info con mínimo para consistencia */
  .product-card-info {
    min-height: 140px;
  }

  /* Mobile-first: imagen más pequeña en móvil */
  @media (max-width: 640px) {
    .product-card-image {
      max-height: 160px;
    }
    
    .product-card-info {
      min-height: 120px;
      padding: 0.75rem;
    }
  }

  /* Hover suave */
  .group:hover .product-card-image img {
    transform: scale(1.05);
  }
</style>
