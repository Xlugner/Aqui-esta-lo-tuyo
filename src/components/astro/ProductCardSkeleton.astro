---
/**
 * COMPONENTE: ProductCardSkeleton
 * 
 * Placeholder animado que se muestra mientras cargan los productos
 * Simula la estructura de una ProductCard real para mejor UX
 */
---

<div class="product-card flex flex-col h-full bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden animate-pulse">
  <!-- Skeleton imagen -->
  <div class="skeleton-image w-full bg-gray-50 flex items-center justify-center">
    <div class="skeleton-img h-full w-full bg-gray-200"></div>
  </div>

  <!-- Skeleton info -->
  <div class="skeleton-info p-3 flex flex-col flex-1">
    <!-- Skeleton título -->
    <div class="skeleton-title h-4 bg-gray-200 rounded w-full"></div>
    <div class="skeleton-title h-4 bg-gray-200 rounded w-2/3 mt-2"></div>

    <!-- Skeleton precio -->
    <div class="skeleton-price h-6 bg-gray-200 rounded w-1/3 mt-auto"></div>

    <!-- Skeleton botón -->
    <div class="skeleton-button h-9 bg-gray-200 rounded-lg w-full mt-2"></div>
  </div>
</div>

<style>
  .skeleton-image {
    height: 160px;
  }

  .skeleton-info {
    min-height: 120px;
  }

  .skeleton-img,
  .skeleton-title,
  .skeleton-price,
  .skeleton-button {
    border-radius: 4px;
  }

  /* Animación de pulso */
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  @media (max-width: 640px) {
    .skeleton-image { height: 120px; }
    .skeleton-info { min-height: 100px; padding: 0.5rem; }
  }
</style>
