<script>
  const form = document.querySelector('form[data-notifications="true"]') as HTMLFormElement;
  
  form?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    
    try {
      const response = await fetch(window.location.href, {
        method: 'POST',
        body: formData,
      });

      if (response.ok) {
        showNotification('success', 'Cambios guardados', 'Los cambios se han guardado correctamente');
        
        setTimeout(() => {
          window.location.reload();
        }, 1000);
      } else {
        showNotification('error', 'Error al guardar', 'Ocurrió un error al guardar los cambios');
      }
    } catch (error) {
      console.error('Form submission error:', error);
      showNotification('error', 'Error inesperado', 'Ocurrió un error inesperado');
    }
  });

  function showNotification(type: string, title: string, message: string) {
    const bgColor: Record<string, string> = {
      success: 'bg-green-50 border-green-200',
      error: 'bg-red-50 border-red-200',
      info: 'bg-blue-50 border-blue-200',
      warning: 'bg-yellow-50 border-yellow-200',
    };

    const textColor: Record<string, string> = {
      success: 'text-green-800',
      error: 'text-red-800',
      info: 'text-blue-800',
      warning: 'text-yellow-800',
    };

    const titleColor: Record<string, string> = {
      success: 'text-green-900',
      error: 'text-red-900',
      info: 'text-blue-900',
      warning: 'text-yellow-900',
    };

    const iconColor: Record<string, string> = {
      success: 'text-green-600',
      error: 'text-red-600',
      info: 'text-blue-600',
      warning: 'text-yellow-600',
    };

    const icons: Record<string, string> = {
      success: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>',
      error: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" /></svg>',
      info: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" /></svg>',
      warning: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>',
    };

    const id = `${Date.now()}-${Math.random()}`;
    const notificationHTML = `
      <div id="${id}" class="${bgColor[type]} border rounded-lg p-4 flex items-start gap-3 animate-in fade-in slide-in-from-top-2 duration-300">
        <div class="${iconColor[type]} flex-shrink-0 mt-0.5">
          ${icons[type]}
        </div>
        <div class="flex-1">
          <h3 class="${titleColor[type]} font-semibold text-sm">
            ${title}
          </h3>
          <p class="${textColor[type]} text-sm mt-1">
            ${message}
          </p>
        </div>
        <button onclick="document.getElementById('${id}').remove()" class="${textColor[type]} hover:opacity-75 flex-shrink-0">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
    `;

    const container = (document.querySelector('.fixed.top-4.right-4') as HTMLElement) || createNotificationContainer();
    const notification = document.createElement('div');
    notification.innerHTML = notificationHTML;
    const element = notification.firstElementChild;
    if (element) {
      container.appendChild(element);
    }

    setTimeout(() => {
      const el = document.getElementById(id);
      if (el) el.remove();
    }, 4000);
  }

  function createNotificationContainer(): HTMLElement {
    const container = document.createElement('div');
    container.className = 'fixed top-4 right-4 z-50 space-y-2 max-w-md';
    document.body.appendChild(container);
    return container;
  }
</script>
