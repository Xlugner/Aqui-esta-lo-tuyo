---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { getSupabaseServer } from '../../../lib/admin-auth';
import { getHeroSection, updateHeroSection } from '../../../lib/supabase';
import type { HeroImage } from '../../../lib/supabase';

const supabase = getSupabaseServer(Astro.cookies);
const heroSection = await getHeroSection();
const existingImages = heroSection?.images || [];

let successMessage: string | undefined;
let errorMessage: string | undefined;

// Manejar actualización
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'update') {
    const imageUrls = formData.getAll('image_url') as string[];
    const altTexts = formData.getAll('alt_text') as string[];
    const actives = formData.getAll('active') as string[];

    const images = imageUrls
      .map((url, index) => ({
        image_url: url.trim(),
        alt_text: altTexts[index]?.trim() || '',
        order_index: index,
        active: true, // Por defecto activas
      }))
      .filter(img => img.image_url);

    if (images.length > 0) {
      const result = await updateHeroSection(images);
      if (result.length > 0) {
        successMessage = 'Imágenes actualizadas correctamente';
      } else {
        errorMessage = 'Error al actualizar las imágenes';
      }
    }
  }
}
---

<AdminLayout title="Hero Section" currentPath="/admin/hero">
  <h1 class="text-2xl font-bold text-neutral-800 mb-6">Imágenes del Hero</h1>

  {successMessage && (
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">
      <p class="text-sm font-medium">{successMessage}</p>
    </div>
  )}

  {errorMessage && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
      <p class="text-sm font-medium">{errorMessage}</p>
    </div>
  )}

  <div class="bg-white rounded-lg shadow p-6">
    <p class="text-neutral-600 mb-6">
      Gestiona las imágenes que aparecen en el carrusel de la página principal.
    </p>

    <form method="POST" id="hero-form" class="space-y-6">
      <input type="hidden" name="action" value="update" />
      
      <div id="images-container" class="space-y-4">
        {existingImages.map((img: HeroImage, index: number) => (
          <div class="image-item border border-neutral-200 rounded-lg p-4">
            <div class="flex items-start gap-4">
              <div class="w-24 h-24 bg-neutral-100 rounded overflow-hidden flex-shrink-0">
                <img src={img.image_url} alt={img.alt_text || ''} class="w-full h-full object-cover" />
              </div>
              <div class="flex-1 space-y-3">
                <div>
                  <label class="block text-sm font-medium text-neutral-700 mb-1">URL de imagen</label>
                  <input
                    type="url"
                    name="image_url"
                    value={img.image_url}
                    class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
                    placeholder="https://ejemplo.com/imagen.jpg"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 mb-1">Texto alternativo</label>
                  <input
                    type="text"
                    name="alt_text"
                    value={img.alt_text || ''}
                    class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
                    placeholder="Descripción de la imagen"
                  />
                </div>
              </div>
              <button
                type="button"
                onclick="removeImage(this)"
                class="p-2 text-red-600 hover:text-red-700 hover:bg-red-50 rounded-lg transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          </div>
        ))}
      </div>

      <button
        type="button"
        onclick="addImage()"
        class="flex items-center gap-2 text-neutral-600 hover:text-neutral-900"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
        </svg>
        Agregar imagen
      </button>

      <div class="flex gap-4 pt-6 border-t border-neutral-200">
        <button
          type="submit"
          class="bg-neutral-900 text-white py-3 px-6 rounded-lg font-medium hover:bg-neutral-800 transition-colors"
        >
          Guardar Cambios
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  function addImage() {
    const container = document.getElementById('images-container');
    const index = container?.children.length || 0;
    
    const div = document.createElement('div');
    div.className = 'image-item border border-neutral-200 rounded-lg p-4';
    div.innerHTML = `
      <div class="flex items-start gap-4">
        <div class="w-24 h-24 bg-neutral-100 rounded overflow-hidden flex-shrink-0 flex items-center justify-center">
          <svg class="w-8 h-8 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="flex-1 space-y-3">
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1">URL de imagen</label>
            <input
              type="url"
              name="image_url"
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
              placeholder="https://ejemplo.com/imagen.jpg"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1">Texto alternativo</label>
            <input
              type="text"
              name="alt_text"
              class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
              placeholder="Descripción de la imagen"
            />
          </div>
        </div>
        <button
          type="button"
          onclick="removeImage(this)"
          class="p-2 text-red-600 hover:text-red-700 hover:bg-red-50 rounded-lg transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        </button>
      </div>
    `;
    
    container?.appendChild(div);
  }

  function removeImage(button: HTMLElement) {
    const item = button.closest('.image-item');
    item?.remove();
  }

  (window as any).addImage = addImage;
  (window as any).removeImage = removeImage;
</script>
