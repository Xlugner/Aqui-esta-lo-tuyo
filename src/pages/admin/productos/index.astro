---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { getSupabaseServer } from '../../../lib/admin-auth';
import { getProducts, getCategories, deleteProduct } from '../../../lib/supabase';

const supabase = getSupabaseServer(Astro.cookies);
const products = await getProducts();
const categories = await getCategories();

// Manejar eliminación
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();
  const productId = formData.get('productId')?.toString();

  if (action === 'delete' && productId) {
    await deleteProduct(productId);
    return Astro.redirect('/admin/productos');
  }
}
---

<AdminLayout title="Productos" currentPath="/admin/productos">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-neutral-800">Productos</h1>
    <a
      href="/admin/productos/nuevo"
      class="bg-neutral-900 text-white px-4 py-2 rounded-lg hover:bg-neutral-800 transition-colors flex items-center gap-2"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
      </svg>
      Nuevo Producto
    </a>
  </div>

  {products.length === 0 ? (
    <div class="bg-white rounded-lg shadow p-12 text-center">
      <svg class="w-16 h-16 mx-auto text-neutral-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
      </svg>
      <p class="text-neutral-500 text-lg mb-4">No hay productos aún</p>
      <a
        href="/admin/productos/nuevo"
        class="text-neutral-900 font-medium hover:underline"
      >
        Crear el primer producto →
      </a>
    </div>
  ) : (
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <table class="w-full">
        <thead class="bg-neutral-50">
          <tr>
            <th class="text-left py-4 px-6 text-sm font-medium text-neutral-500">Producto</th>
            <th class="text-left py-4 px-6 text-sm font-medium text-neutral-500">Precio</th>
            <th class="text-left py-4 px-6 text-sm font-medium text-neutral-500">Categoría</th>
            <th class="text-left py-4 px-6 text-sm font-medium text-neutral-500">Estado</th>
            <th class="text-right py-4 px-6 text-sm font-medium text-neutral-500">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {products.map((product) => (
            <tr class="border-t border-neutral-100 hover:bg-neutral-50">
              <td class="py-4 px-6">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 bg-neutral-100 rounded-lg flex items-center justify-center overflow-hidden">
                    {product.images?.[0] ? (
                      <img
                        src={product.images[0].image_url}
                        alt={product.name}
                        class="w-12 h-12 object-cover"
                      />
                    ) : (
                      <svg class="w-6 h-6 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    )}
                  </div>
                  <div>
                    <p class="font-medium text-neutral-800">{product.name}</p>
                    <p class="text-sm text-neutral-500 truncate max-w-xs">{product.description?.substring(0, 50)}...</p>
                  </div>
                </div>
              </td>
              <td class="py-4 px-6 text-neutral-600">
                ${product.price.toLocaleString()} {product.currency}
              </td>
              <td class="py-4 px-6 text-neutral-600">
                {product.category?.name || '-'}
              </td>
              <td class="py-4 px-6">
                {product.featured ? (
                  <span class="px-2 py-1 bg-yellow-100 text-yellow-700 text-xs rounded-full font-medium">
                    Destacado
                  </span>
                ) : (
                  <span class="px-2 py-1 bg-neutral-100 text-neutral-600 text-xs rounded-full">
                    Normal
                  </span>
                )}
              </td>
              <td class="py-4 px-6">
                <div class="flex items-center justify-end gap-2">
                  <a
                    href={`/admin/productos/${product.id}/editar`}
                    class="p-2 text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100 rounded-lg transition-colors"
                    title="Editar"
                  >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  </a>
                  <form method="POST" class="inline">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="productId" value={product.id} />
                    <button
                      type="submit"
                      class="p-2 text-red-600 hover:text-red-700 hover:bg-red-50 rounded-lg transition-colors"
                      title="Eliminar"
                      onclick="return confirm('¿Estás seguro de eliminar este producto?')"
                    >
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
