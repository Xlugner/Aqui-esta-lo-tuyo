---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { getSupabaseServer } from '../../../lib/admin-auth';
import { getStoreConfig, updateStoreConfig } from '../../../lib/supabase';
import type { StoreConfig } from '../../../lib/supabase';

const supabase = getSupabaseServer(Astro.cookies);
const config = await getStoreConfig();

let successMessage: string | undefined;
let errorMessage: string | undefined;

// Manejar actualización
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();

  const newConfig: Partial<StoreConfig> = {
    store_name: formData.get('store_name')?.toString() || '',
    description: formData.get('description')?.toString() || undefined,
    logo_url: formData.get('logo_url')?.toString() || undefined,
    email: formData.get('email')?.toString() || undefined,
    phone: formData.get('phone')?.toString() || undefined,
    whatsapp_number: formData.get('whatsapp_number')?.toString() || undefined,
    address: formData.get('address')?.toString() || undefined,
    facebook_url: formData.get('facebook_url')?.toString() || undefined,
    instagram_url: formData.get('instagram_url')?.toString() || undefined,
    twitter_url: formData.get('twitter_url')?.toString() || undefined,
  };

  // Mantener el ID si existe
  if (config?.id) {
    newConfig.id = config.id;
  }

  const result = await updateStoreConfig(newConfig, supabase);

  if (result) {
    successMessage = 'Configuración actualizada correctamente';
  } else {
    errorMessage = 'Error al actualizar la configuración';
  }
}
---

<AdminLayout title="Configuración" currentPath="/admin/configuracion">
  <h1 class="text-2xl font-bold text-neutral-800 mb-6">Configuración de la Tienda</h1>

  {successMessage && (
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">
      <p class="text-sm font-medium">{successMessage}</p>
    </div>
  )}

  {errorMessage && (
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
      <p class="text-sm font-medium">{errorMessage}</p>
    </div>
  )}

  <form method="POST" class="bg-white rounded-lg shadow p-6 space-y-6">
    <!-- Información General -->
    <div>
      <h2 class="text-lg font-semibold text-neutral-800 mb-4">Información General</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="store_name" class="block text-sm font-medium text-neutral-700 mb-2">
            Nombre de la tienda
          </label>
          <input
            type="text"
            id="store_name"
            name="store_name"
            value={config?.store_name || ''}
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
          />
        </div>
        <div>
          <label for="logo_url" class="block text-sm font-medium text-neutral-700 mb-2">
            URL del Logo
          </label>
          <input
            type="url"
            id="logo_url"
            name="logo_url"
            value={config?.logo_url || ''}
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
            placeholder="https://ejemplo.com/logo.png"
          />
        </div>
      </div>
      <div class="mt-4">
        <label for="description" class="block text-sm font-medium text-neutral-700 mb-2">
          Descripción
        </label>
        <textarea
          id="description"
          name="description"
          rows="3"
          class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
        >{config?.description || ''}</textarea>
      </div>
    </div>

    <!-- Contacto -->
    <div class="border-t border-neutral-200 pt-6">
      <h2 class="text-lg font-semibold text-neutral-800 mb-4">Contacto</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            value={config?.email || ''}
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
          />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium text-neutral-700 mb-2">
            Teléfono
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            value={config?.phone || ''}
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
          />
        </div>
        <div>
          <label for="whatsapp_number" class="block text-sm font-medium text-neutral-700 mb-2">
            WhatsApp (solo número, con código de país)
          </label>
          <input
            type="text"
            id="whatsapp_number"
            name="whatsapp_number"
            value={config?.whatsapp_number || ''}
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
            placeholder="53123456789"
          />
        </div>
        <div>
          <label for="address" class="block text-sm font-medium text-neutral-700 mb-2">
            Dirección
          </label>
          <input
            type="text"
            id="address"
            name="address"
            value={config?.address || ''}
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
          />
        </div>
      </div>
    </div>

    <!-- Redes Sociales -->
    <div class="border-t border-neutral-200 pt-6">
      <h2 class="text-lg font-semibold text-neutral-800 mb-4">Redes Sociales</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label for="facebook_url" class="block text-sm font-medium text-neutral-700 mb-2">
            Facebook URL
          </label>
          <input
            type="url"
            id="facebook_url"
            name="facebook_url"
            value={config?.facebook_url || ''}
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
            placeholder="https://facebook.com/mitienda"
          />
        </div>
        <div>
          <label for="instagram_url" class="block text-sm font-medium text-neutral-700 mb-2">
            Instagram URL
          </label>
          <input
            type="url"
            id="instagram_url"
            name="instagram_url"
            value={config?.instagram_url || ''}
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
            placeholder="https://instagram.com/mitienda"
          />
        </div>
        <div>
          <label for="twitter_url" class="block text-sm font-medium text-neutral-700 mb-2">
            Twitter/X URL
          </label>
          <input
            type="url"
            id="twitter_url"
            name="twitter_url"
            value={config?.twitter_url || ''}
            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-neutral-900 focus:border-transparent"
            placeholder="https://twitter.com/mitienda"
          />
        </div>
      </div>
    </div>

    <!-- Submit -->
    <div class="flex gap-4 pt-6 border-t border-neutral-200">
      <button
        type="submit"
        class="bg-neutral-900 text-white py-3 px-6 rounded-lg font-medium hover:bg-neutral-800 transition-colors"
      >
        Guardar Cambios
      </button>
    </div>
  </form>
</AdminLayout>
