---
import Layout from "../layouts/Layout.astro";
import { CheckoutForm } from "../components/react/CheckoutForm";
import { CartSummary } from "../components/react/CartSummary";
import BackButton from "../components/astro/BackButton.astro";
---

<Layout title="Finalizar Compra">
  <div class="container mx-auto px-4 py-8">
    <BackButton />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Formulario de checkout -->
      <CheckoutForm client:load />

      <!-- Resumen del carrito -->
      <CartSummary client:load />
    </div>
  </div>
</Layout>
