# ============================================
# VARIABLES PÚBLICAS (van en .env local y producción)
# ============================================

# Configuración de Supabase (PÚBLICO)
# Obtén estas claves de tu proyecto en https://supabase.com
# Settings > API > Project URL y anon key
# Estas claves son públicas y se envían al cliente
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Configuración de la Tienda (PÚBLICO)
PUBLIC_STORE_NAME="Mi Tienda Online"
PUBLIC_STORE_DESCRIPTION="Descripción de tu tienda"
PUBLIC_STORE_EMAIL=contacto@mitienda.com
PUBLIC_STORE_PHONE=34123456789
PUBLIC_STORE_LOCATION="Tu ubicación"
PUBLIC_WHATSAPP_NUMBER=34123456789

# ============================================
# VARIABLES PRIVADAS (solo en producción)
# ============================================

# Configuración Admin (PRIVADO - solo servidor)
# NO incluir en .env local si no es necesario
# En producción, configura estas en tu plataforma de hosting
ADMIN_EMAIL=admin@tienda.com
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# Base de Datos (PRIVADO - solo para migraciones)
DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# NOTAS DE SEGURIDAD
# ============================================
# 1. Las variables PUBLIC_* son públicas (se envían al cliente)
#    - Úsalas para URLs, claves públicas de APIs, etc.
#    - NO incluyas secretos aquí
#
# 2. Las variables privadas (sin PUBLIC_) nunca se envían al cliente
#    - Úsalas para contraseñas, API keys privadas, etc.
#    - En desarrollo local, puedes incluirlas en .env
#    - En producción, configúralas en tu plataforma de hosting
#
# 3. El .gitignore protege .env de ser commiteado
#    - Pero .env.example SÍ debe estar en el repositorio
#    - .env.example es una plantilla sin valores reales
#
# 4. Para producción:
#    - Copia los valores de .env.example
#    - Reemplaza con valores reales
#    - Configúralos en tu plataforma (Vercel, Netlify, Railway, etc.)
#    - NUNCA los commits al repositorio
